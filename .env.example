############
# HOW TO USE
#
# Copy this file and rename it for your instance:
#   cp .env.example .env.homelab
#   cp .env.example .env.prod
#
# Fill in all values marked CHANGE_ME or generate them (see comments).
# Upload the renamed file as the environment file when creating a Portainer stack.
#
# Never commit .env.* files — they are gitignored.
############


############
# Secrets — generate before first deploy
#
# Quick generation (requires openssl + node):
#   POSTGRES_PASSWORD:   openssl rand -base64 32
#   JWT_SECRET:          openssl rand -base64 48
#   SECRET_KEY_BASE:     openssl rand -base64 64
#   VAULT_ENC_KEY:       openssl rand -base64 24 | head -c 32
#   PG_META_CRYPTO_KEY:  openssl rand -base64 24 | head -c 32
#   LOGFLARE_*:          openssl rand -hex 32
#   S3_PROTOCOL_*:       openssl rand -hex 16 / openssl rand -hex 32
#
# For ANON_KEY / SERVICE_ROLE_KEY (JWT tokens signed with JWT_SECRET):
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
############

# Postgres
POSTGRES_PASSWORD=CHANGE_ME

# Legacy symmetric HS256 JWT secret (32+ chars)
JWT_SECRET=CHANGE_ME_at_least_32_characters_long

# Legacy API keys — HS256 JWTs signed with JWT_SECRET above
# Generate at: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
ANON_KEY=CHANGE_ME
SERVICE_ROLE_KEY=CHANGE_ME

# Asymmetric ES256 opaque API keys (optional — leave blank to use legacy HS256 keys only)
# Generate with: sh utils/add-new-auth-keys.sh (from the official supabase/supabase repo)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

# Dashboard credentials
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=CHANGE_ME

# Realtime + Supavisor (64+ chars)
SECRET_KEY_BASE=CHANGE_ME_64_chars_minimum

# Supavisor encryption key (exactly 32 chars)
VAULT_ENC_KEY=CHANGE_ME_32_characters_exactly_!

# postgres-meta crypto key (32+ chars)
PG_META_CRYPTO_KEY=CHANGE_ME_32_characters_minimum_!

# Analytics log ingestion tokens
LOGFLARE_PUBLIC_ACCESS_TOKEN=CHANGE_ME
LOGFLARE_PRIVATE_ACCESS_TOKEN=CHANGE_ME

# Storage S3 protocol endpoint credentials
S3_PROTOCOL_ACCESS_KEY_ID=CHANGE_ME_16_hex_chars
S3_PROTOCOL_ACCESS_KEY_SECRET=CHANGE_ME_32_hex_chars


############
# URLs — set to your actual domain or IP
############

# Public URL of the Kong gateway (Studio + REST API entry point)
SUPABASE_PUBLIC_URL=http://localhost:8000

# Auth service external URL (used for OAuth callbacks and email links)
API_EXTERNAL_URL=http://localhost:8000

# Your app's site URL (Auth redirects here after login)
SITE_URL=http://localhost:3000


############
# Database
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432


############
# Supavisor — connection pooler
############

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5

# Unique identifier for this Supabase instance (any short string, no spaces)
POOLER_TENANT_ID=my-instance


############
# Studio
############

STUDIO_DEFAULT_ORGANIZATION=My Organization
STUDIO_DEFAULT_PROJECT=My Project

# Optional: enable AI Assistant in Studio
OPENAI_API_KEY=


############
# Auth
############

ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

# SMTP — required for email auth (invites, password reset, etc.)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_SENDER_NAME=Supabase

ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# OAuth providers — also uncomment matching GOTRUE_EXTERNAL_* lines in docker-compose.yml
# GOOGLE_ENABLED=false
# GOOGLE_CLIENT_ID=
# GOOGLE_SECRET=

# GITHUB_ENABLED=false
# GITHUB_CLIENT_ID=
# GITHUB_SECRET=


############
# Storage
############

GLOBAL_S3_BUCKET=stub
REGION=stub
STORAGE_TENANT_ID=stub


############
# Edge Functions
############

FUNCTIONS_VERIFY_JWT=false


############
# API / PostgREST
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public


############
# Analytics / Vector
############

# Docker socket path (use /run/podman/podman.sock for Podman)
DOCKER_SOCKET_LOCATION=/var/run/docker.sock

GOOGLE_PROJECT_ID=
GOOGLE_PROJECT_NUMBER=


############
# Kong gateway ports
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443


############
# imgproxy
############

IMGPROXY_AUTO_WEBP=true
